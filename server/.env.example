# ─── Auth Mode ───────────────────────────────────────────────
# On Cloud Run, use Vertex AI mode (ADC — no API key required):
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=gen-lang-client-0001923421
GOOGLE_CLOUD_LOCATION=global

# ─── Local Dev (API Key Mode) ───────────────────────────────
# For local development, set GOOGLE_GENAI_USE_VERTEXAI=FALSE
# and provide an API key instead:
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Server port (Cloud Run uses 8080 by default)
PORT=8080
