# ─────────────────────────────────────────────────────────────────────────────
# OmniWeave — Environment Configuration
# Copy this to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# GEMINI API KEY (Required)
# Get from: https://ai.google.dev/ or Google Cloud Console
# Used as fallback when ADK server is unavailable
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ADK AGENT SERVER URL (Optional)
# Set this to your Cloud Run URL after deploying the server/
# When set, image generation and embeddings route through Cloud Run
# keeping the API key server-side (more secure).
# Example: https://omniweave-adk-abc123-uc.a.run.app
VITE_ADK_SERVER_URL=""

# APP URL (Auto-injected by AI Studio)
APP_URL="MY_APP_URL"
