# OmniWeave — Environment Configuration
# Copy to .env.local and fill in your values

# Gemini API Key for browser/direct mode.
# In Vite, client-exposed env vars must use the VITE_ prefix.
# Get from: https://ai.google.dev/
VITE_GEMINI_API_KEY=""

# Optional server-only alias used by some local tooling.
# This is NOT exposed to the browser unless you also set VITE_GEMINI_API_KEY.
GEMINI_API_KEY=""

# ADK Agent Server URL (optional)
# When set, routes image gen + embeddings through Cloud Run
VITE_ADK_SERVER_URL=""
