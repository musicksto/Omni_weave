rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // OmniWeave Firestore Security Rules
    // Per-user data isolation with anonymous auth support
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.resource.data.authorId == request.auth.uid;
    }

    // ===============================================================
    // Stories — per-user isolated, anonymous auth supported
    // ===============================================================
    match /stories/{storyId} {
      // Users can only read their own stories
      allow read: if isDocOwner();

      // Users can create stories if authenticated and authorId matches their uid
      // Required fields: authorId, title, parts, createdAt
      // Optional fields: review, embedding
      allow create: if isAuthenticated()
                    && isNewDocOwner()
                    && request.resource.data.keys().hasAll(['authorId', 'title', 'parts', 'createdAt'])
                    && request.resource.data.authorId is string
                    && request.resource.data.title is string
                    && request.resource.data.parts is string;

      // Users can update their own stories (authorId immutable)
      allow update: if isDocOwner()
                    && request.resource.data.authorId == resource.data.authorId;

      // Users can delete their own stories
      allow delete: if isDocOwner();

      // Story images subcollection — per-user isolated
      match /images/{imageId} {
        allow read: if isAuthenticated()
                    && get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid;
        allow create: if isAuthenticated()
                      && get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid;
        allow delete: if isAuthenticated()
                      && get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid;
      }

      // Story audio subcollection — per-user isolated
      match /audio/{audioId} {
        allow read: if isAuthenticated()
                    && get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid;
        allow create: if isAuthenticated()
                      && get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid;
        allow delete: if isAuthenticated()
                      && get(/databases/$(database)/documents/stories/$(storyId)).data.authorId == request.auth.uid;
      }
    }

    // ===============================================================
    // Users — profile data, per-user isolated
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // No self-deletion
    }

    // ===============================================================
    // Deny all other collections
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
